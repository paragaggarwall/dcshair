// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  userName  String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  createdBy String?
  role      Role     @default(User)
}

model Customer {
  id             Int             @id @default(autoincrement())
  name           String
  email          String?         @unique
  address        String?
  phone          String?
  altPhone       String?
  city           String?
  state          String?
  country        String?
  pinCode        String?
  createdAt      DateTime        @default(now())
  createdBy      String?
  contracts      Contract[]
  consignees     Consignee[]
  buyers         Buyer[]
  notifyParties  NotifyParty[]
  contactPersons ContactPerson[]
}

model Consignee {
  id         Int        @id @default(autoincrement())
  name       String
  email      String?
  address    String?
  phone      String?
  altPhone   String?
  city       String?
  state      String?
  country    String?
  pinCode    String?
  createdAt  DateTime   @default(now())
  createdBy  String?
  customerId Int
  customer   Customer   @relation(fields: [customerId], references: [id])
  contracts  Contract[]
}

model Buyer {
  id         Int        @id @default(autoincrement())
  name       String
  email      String?
  address    String?
  phone      String?
  altPhone   String?
  city       String?
  state      String?
  country    String?
  pinCode    String?
  createdAt  DateTime   @default(now())
  createdBy  String?
  customerId Int
  customer   Customer   @relation(fields: [customerId], references: [id])
  contracts  Contract[]
}

model NotifyParty {
  id         Int        @id @default(autoincrement())
  name       String
  email      String?
  address    String?
  phone      String?
  altPhone   String?
  city       String?
  state      String?
  country    String?
  pinCode    String?
  createdAt  DateTime   @default(now())
  createdBy  String?
  customerId Int
  customer   Customer   @relation(fields: [customerId], references: [id])
  contracts  Contract[]
}

model ContactPerson {
  id         Int        @id @default(autoincrement())
  name       String
  email      String?
  phone      String?
  altPhone   String?
  createdAt  DateTime   @default(now())
  createdBy  String?
  customerId Int
  customer   Customer   @relation(fields: [customerId], references: [id])
  contracts  Contract[]
}

model Product {
  id            Int            @id @default(autoincrement())
  name          String
  size          String?
  pricePerKg    Float          @default(0)
  imageUrl      String?
  skuCode       String
  createdAt     DateTime       @default(now())
  createdBy     String?
  contract      Contract?      @relation(fields: [contractId], references: [id])
  contractId    Int?
  contractItems ContractItem[]
}

model TermsOfPayment {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  createdAt DateTime   @default(now())
  createdBy String?
  contracts Contract[]
}

model Contract {
  id                     Int             @id @default(autoincrement())
  name                   String
  customerId             Int
  customer               Customer        @relation(fields: [customerId], references: [id])
  consigneeId            Int?
  consignee              Consignee?      @relation(fields: [consigneeId], references: [id])
  buyerId                Int?
  buyer                  Buyer?          @relation(fields: [buyerId], references: [id])
  notifyPartyId          Int?
  notifyParty            NotifyParty?    @relation(fields: [notifyPartyId], references: [id])
  contactPersonId        Int?
  contactPerson          ContactPerson?  @relation(fields: [contactPersonId], references: [id])
  termsOfPaymentId       Int
  termsOfPayment         TermsOfPayment  @relation(fields: [termsOfPaymentId], references: [id])
  createdAt              DateTime        @default(now())
  createdBy              String
  products               Product[]
  countryOfOrigin        String
  countryOfDestination   String
  description            String?
  packing                String?
  insurance              String?
  preCarriageBy          Carrier?
  portOfLoading          String?
  portOfFinalDestination String?
  operatingAirlines      String?
  speacialCondition      String?
  note                   String?
  expectedDepartureDate  DateTime?
  expectedDeliveryDate   DateTime?
  contractItems          ContractItem[]
}

model ContractItem {
  id          Int      @id @default(autoincrement())
  contractId  Int
  contract    Contract @relation(fields: [contractId], references: [id])
  productId   Int
  product     Product  @relation(fields: [productId], references: [id])
  quantity    Float
  pricePerKg  Float
  totalAmount Float
}

enum Carrier {
  Sea
  Air
  Road
}

enum Role {
  Admin
  User
}
